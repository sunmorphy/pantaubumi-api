# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/pantaubumi

# ─── External APIs ─────────────────────────────────────────────────────────────
# BMKG open data (no key required for public endpoints)
BMKG_BASE_URL=https://data.bmkg.go.id/DataMKG/TEWS

# Open-Meteo (no key required)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# USGS Earthquake API (no key required)
USGS_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1/query

# PetaBencana (no key required for public read)
PETABENCANA_BASE_URL=https://data.petabencana.id/floods/reports

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON file, OR paste the JSON content
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Alternatively, paste the JSON as a single-line string:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
CORS_ORIGINS=*

# ─── Scheduler ─────────────────────────────────────────────────────────────────
INGESTION_INTERVAL_MINUTES=5

# ─── AI Model Paths ────────────────────────────────────────────────────────────
FLOOD_MODEL_PATH=app/ai/weights/flood_model.pkl
LANDSLIDE_MODEL_PATH=app/ai/weights/landslide_model.pkl
